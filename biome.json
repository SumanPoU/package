{
  "$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!node_modules",
      "!.next",
      "!dist",
      "!build",
      "!**/tmp-geo",
      "!**/public/r"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "noSvgWithoutTitle": "off"
      },
      "style": {
        "noNonNullAssertion": "off"
      },
      "suspicious": {
        "noUnknownAtRules": "off",
        "noControlCharactersInRegex": "off"
      },
      "correctness": {
        "noInvalidPositionAtImportRule": "off"
      }
    },
    "domains": {
      "next": "recommended",
      "react": "recommended"
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["packages/**"],
      "linter": {
        "domains": {
          "next": "none"
        },
        "rules": {
          "a11y": {
            "useSemanticElements": "off",
            "noStaticElementInteractions": "off",
            "noAutofocus": "off",
            "noLabelWithoutControl": "off",
            "noSvgWithoutTitle": "off",
            "useAriaPropsSupportedByRole": "off",
            "useAriaPropsForRole": "off",
            "useKeyWithClickEvents": "off",
            "useFocusableInteractive": "off",
            "noNoninteractiveElementInteractions": "off"
          },
          "performance": {
            "noImgElement": "off"
          },
          "style": {
            "noDescendingSpecificity": "off",
            "noNonNullAssertion": "off"
          },
          "suspicious": {
            "noArrayIndexKey": "off",
            "noControlCharactersInRegex": "off"
          },
          "correctness": {
            "noUnusedFunctionParameters": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.css"],
      "linter": {
        "rules": {
          "style": {
            "noDescendingSpecificity": "off"
          },
          "correctness": {
            "noInvalidPositionAtImportRule": "off"
          }
        }
      }
    }
  ]
}
