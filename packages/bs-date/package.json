{
  "name": "@itzsa/bs-date",
  "version": "0.1.0",
  "description": "Headless Bikram Sambat (Nepali) date logic — convert, arithmetic, format, holidays (no UI)",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "nepal",
    "bikram-sambat",
    "bs",
    "nepali-date",
    "calendar",
    "conversion",
    "date-arithmetic",
    "headless",
    "itzsa"
  ],
  "homepage": "https://itzsa.acharya-suman.com.np/bs-date",
  "bugs": {
    "url": "https://github.com/SumanPoU/package/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SumanPoU/package.git",
    "directory": "packages/bs-date"
  }
}
