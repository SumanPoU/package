{
  "name": "@itzsa/editor",
  "version": "0.2.2",
  "description": "Company-standard TipTap rich text editor with Nepali input, language lock, and hardened sanitization",
  "license": "MIT",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./styles.css": "./src/styles.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src/styles.css",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm run typecheck && pnpm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@itzsa/nepali-input": "workspace:*",
    "@tiptap/core": "^3.22.1",
    "@tiptap/extension-character-count": "^3.22.1",
    "@tiptap/extension-highlight": "^3.22.1",
    "@tiptap/extension-image": "^3.22.1",
    "@tiptap/extension-placeholder": "^3.22.1",
    "@tiptap/extension-subscript": "^3.22.1",
    "@tiptap/extension-superscript": "^3.22.1",
    "@tiptap/extension-table": "^3.22.1",
    "@tiptap/extension-table-cell": "^3.22.1",
    "@tiptap/extension-table-header": "^3.22.1",
    "@tiptap/extension-table-row": "^3.22.1",
    "@tiptap/extension-task-item": "^3.22.1",
    "@tiptap/extension-task-list": "^3.22.1",
    "@tiptap/extension-text-align": "^3.22.1",
    "@tiptap/extension-text-style": "^3.22.1",
    "@tiptap/pm": "^3.22.1",
    "@tiptap/react": "^3.22.1",
    "@tiptap/starter-kit": "^3.22.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.525.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsup": "^8.5.0",
    "typescript": "^5"
  },
  "keywords": [
    "tiptap",
    "rich-text",
    "editor",
    "nepali",
    "preeti",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SumanPoU/package.git",
    "directory": "packages/editor"
  }
}
