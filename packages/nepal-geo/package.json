{
  "name": "@itzsa/nepal-geo",
  "version": "0.2.1",
  "description": "Nepal provinces, districts, local levels & wards — React selects + data helpers",
  "license": "MIT",
  "sideEffects": [
    "**/*.css",
    "./src/styles.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./styles.css": "./src/styles.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src/styles.css",
    "README.md"
  ],
  "scripts": {
    "generate:data": "node scripts/generate-data.mjs",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm run typecheck && pnpm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@itzsa/nepal-geo-data": "workspace:*",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsup": "^8.5.0",
    "typescript": "^5"
  },
  "keywords": [
    "nepal",
    "province",
    "district",
    "municipality",
    "metropolitan",
    "ward",
    "local-level",
    "geography",
    "select",
    "react"
  ],
  "homepage": "https://itzsa.acharya-suman.com.np/nepal-geo",
  "bugs": {
    "url": "https://github.com/SumanPoU/package/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SumanPoU/package.git",
    "directory": "packages/nepal-geo"
  }
}
