{
  "name": "@itzsa/nepali-input",
  "version": "0.1.2",
  "description": "Nepali (Unicode / Preeti) transliterating Input and Textarea for React",
  "license": "MIT",
  "sideEffects": [
    "**/*.css",
    "./src/styles.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./styles.css": "./src/styles.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src/styles.css",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm run typecheck && pnpm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsup": "^8.5.0",
    "typescript": "^5"
  },
  "keywords": [
    "nepali",
    "preeti",
    "unicode",
    "devanagari",
    "react",
    "input",
    "textarea",
    "transliteration"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SumanPoU/package.git",
    "directory": "packages/nepali-input"
  }
}
